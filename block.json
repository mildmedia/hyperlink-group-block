{
	"apiVersion": 3,
	"name": "tiptip/hyperlink-group-block",
	"title": "Hyperlink Group",
	"category": "design",
	"supports": {
		"html": true,
		"anchor": true,
		"align": true,
		"color": {
			"text": true,
			"background": true,
			"hover": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"__experimentalBorder": {
			"color": true,
			"width": true,
			"style": true,
			"radius": true
		},
		"interactivity": {
			"clientNavigation": true
		}
	},
	"usesContext": [
		"postId",
		"postType",
		"queryId"
	],
	"attributes": {
		"colorBkgHover": {
			"type": "string"
		},
		"colorTextHover": {
			"type": "string"
		},
		"url": {
			"type": "string"
		},
		"title": {
			"type": "string"
		},
		"linkTarget": {
			"type": "string"
		},
		"ariaLabel": {
			"type": "string"
		},
		"rel": {
			"type": "string"
		},
		"queryLoopLink": {
			"type": "boolean",
			"default": false
		}
	},
	"textdomain": "hyperlink-group-block",
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:./build/style-index.css",
	"style": "file:./build/style-index.css"
}